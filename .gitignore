# ====================================================================
# Go / Gin Specific
# ====================================================================
# Compiled binaries and executables
bin/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Main application binary (if you name it after your project)
*.test
*.out

# Gin / Air (Live Reload) temporary binaries
# If you use cosmtrek/air for live-reloading Gin
tmp/

# Dependency directories
# (Uncomment vendor/ if you do NOT want to commit your vendored dependencies)
# vendor/

# Go build cache
.go-build/


# ====================================================================
# JetBrains GoLand IDE
# ====================================================================
.idea/
# If you want to share GoLand data sources or tasks, uncomment these:
# !.idea/datasources.xml
# !.idea/tasks.xml


# ====================================================================
# Environment & Secrets (Crucial for Gin apps)
# ====================================================================
# Never commit credentials, API keys, or local port configurations
*.env
*.env.*
!.env.example
config.local.yaml
config.local.json


# ====================================================================
# Operating System Files
# ====================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Ehthumbs.db
Desktop.ini

# ====================================================================
# Dependencies
# ====================================================================
node_modules/
.pnpm-store/
jspm_packages/
web_modules/

# ====================================================================
# Production Builds
# ====================================================================
dist/
build/
out/
.next/

# ====================================================================
# Environment & Secrets
# ====================================================================
# Local env files that contain sensitive API keys/secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Do NOT ignore the template file
!.env.example

# ====================================================================
# Logs and Diagnostics
# ====================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ====================================================================
# IDEs and Editors
# ====================================================================
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ====================================================================
# Testing and Coverage
# ====================================================================
/coverage
.nyc_output

